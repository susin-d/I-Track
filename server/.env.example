# Server
NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173

# SMTP transactional email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-smtp-app-password
SMTP_FROM=your-email@example.com
SMTP_FROM_NAME=I-TRACK

# Database
# The server tries SUPABASE_DATABASE_URL first, then DATABASE_URL when the first
# value is missing or cannot be reached during startup.
DATABASE_URL=postgresql://jiira:jiira_dev_password@127.0.0.1:5433/jiira
SUPABASE_DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
DATABASE_CONNECT_TIMEOUT_MS=5000
DATABASE_POOL_MAX=1
DATABASE_IDLE_TIMEOUT_MS=5000
PERFORMANCE_LOGGING=false
WORKSPACE_MEMBERSHIP_CACHE_TTL_MS=5000

# Authentication - generate a long random value for production
JWT_SECRET=replace-with-a-long-random-secret

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://api.itrack.susindran.in/api/v1/auth/google/callback

# AI provider - optional unless AI endpoints are used
OPENAI_API_KEY=
OPENAI_BASE_URL=https://opencode.ai/zen/v1
OPENAI_MODEL=
OPENAI_CHAT_MODEL=
